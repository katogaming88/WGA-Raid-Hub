{
  "env": {
    "browser": true,
    "es2020": true
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": "off",
    "no-undef": "off",
    "no-console": "off",
    "no-redeclare": "warn",
    "no-empty": "warn"
  },
  "overrides": [
    {
      "files": ["scripts/**/*.js"],
      "env": {
        "browser": false,
        "node": true,
        "es2022": true
      },
      "parserOptions": {
        "sourceType": "module"
      }
    }
  ]
}
